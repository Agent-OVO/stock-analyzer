# ========================================
# A股自选股智能分析系统 - 配置文件模板
# ========================================
# 使用方法：
# 1. 复制此文件为 .env
# 2. 填写您的API密钥和配置
# 3. Windows用户注意：某些系统可能无法识别.env文件，可直接使用文件名.env

# ========================================
# LLM 配置（至少配置一个）
# ========================================

# ┌──────────────────────────────────────────────┐
# │ Google Gemini（推荐新手，有免费额度）        │
# └──────────────────────────────────────────────┘
# 获取地址: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
# 可选模型: gemini-2.0-flash, gemini-2.5-pro-exp-03-25
GEMINI_MODEL=gemini-2.0-flash

# ┌──────────────────────────────────────────────┐
# │ DeepSeek（性价比高，中文好）                   │
# └──────────────────────────────────────────────┘
# 获取地址: https://platform.deepseek.com/
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# ┌──────────────────────────────────────────────┐
# │ OpenAI（经典选择）                            │
# └──────────────────────────────────────────────┘
# 获取地址: https://platform.openai.com/
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini

# ┌──────────────────────────────────────────────┐
# │ Anthropic Claude（长文本强）                  │
# └──────────────────────────────────────────────┘
# 获取地址: https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ┌──────────────────────────────────────────────┐
# │ Ollama（本地运行，完全免费）                   │
# └──────────────────────────────────────────────┘
# 下载地址: https://ollama.com/
# 安装后执行: ollama pull qwen2.5:7b
# OPENAI_API_BASE=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# LLM_MODEL=openai/qwen2.5:7b

# ========================================
# 股票配置
# ========================================

# 自选股列表（逗号分隔）
# 示例: 600519,000001,300750
# 常用代码:
#   600519 - 贵州茅台
#   000001 - 平安银行
#   300750 - 宁德时代
#   600036 - 招商银行
#   000002 - 万科A
STOCK_LIST=600519,000001,300750

# ========================================
# 通知配置（可选，至少配置一个）
# ========================================

# 微信企业群机器人
# 获取方式: 企业微信群 -> 群设置 -> 群机器人 -> 添加机器人
# WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx

# 钉钉群机器人
# 获取方式: 钉钉群 -> 群设置 -> 智能群助手 -> 添加机器人 -> 自定义
# DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx
# DINGTALK_SIGN_SECRET=SECxxxxx

# 飞书群机器人
# 获取方式: 飞书群 -> 群设置 -> 群机器人 -> 添加机器人
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# Telegram推送
# 获取方式: 向 @BotFather 发送 /newtoken
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_CHAT_ID=your_chat_id
# TELEGRAM_MESSAGE_THREAD_ID=your_thread_id

# 邮件推送
# EMAIL_SENDER=your_email@qq.com
# EMAIL_PASSWORD=your_authorization_code
# EMAIL_RECEIVERS=receiver1@qq.com,receiver2@qq.com
# EMAIL_SMTP_SERVER=smtp.qq.com
# EMAIL_SMTP_PORT=587

# Server酱³推送
# 获取地址: https://sct.ftqq.com/
# SERVERCHAN3_SENDKEY=your_sendkey

# 自定义Webhook（多个用逗号分隔）
# CUSTOM_WEBHOOK_URLS=https://your-webhook-1.com,https://your-webhook-2.com

# ========================================
# 数据源配置（可选）
# ========================================

# Tushare数据源（需要Token）
# 获取地址: https://tushare.pro/
# TUSHARE_TOKEN=your_tushare_token

# 新闻搜索API（可选，用于获取最新资讯）
# Tavily: https://tavily.com/
# TAVILY_API_KEYS=your_tavily_key_1,your_tavily_key_2

# SerpAPI: https://serpapi.com/
# SERPAPI_API_KEYS=your_serpapi_key

# ========================================
# 系统配置
# ========================================

# 调试模式（true/false）
DEBUG=false

# 日志级别（DEBUG/INFO/WARNING/ERROR）
LOG_LEVEL=INFO

# 报告语言（zh-CN/zh-TW/en-US）
REPORT_LANGUAGE=zh-CN

# 定时任务配置
SCHEDULE_ENABLED=false
SCHEDULE_TIME=18:00

# 大盘复盘开关
MARKET_REVIEW_ENABLED=true

# ========================================
# 代理配置（如果需要）
# ========================================

# HTTP代理地址
# HTTP_PROXY=http://127.0.0.1:10809
# HTTPS_PROXY=http://127.0.0.1:10809

# ========================================
# Web界面配置
# ========================================

# Web服务监听地址
WEBUI_HOST=0.0.0.0
WEBUI_PORT=8000

# ========================================
# 提示
# ========================================
#
# 1. 首次使用建议只配置一个LLM（推荐Gemini）
# 2. API Key不要泄露给他人
# 3. .env文件不要提交到Git
# 4. Windows用户如果无法创建.env文件，可使用命令：
#    type .env.example > .env
